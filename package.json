{
  "name": "ai-agent-game-planning",
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "orchestrator:build": "tsc -p orchestrator/tsconfig.json",
    "orchestrator:type-check": "tsc -p orchestrator/tsconfig.json --noEmit",
    "generate": "npm run orchestrator:build --silent && node orchestrator/dist/generate.js",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "dependencies": {
    "@types/jszip": "^3.4.0",
    "highlight.js": "^11.9.0",
    "jszip": "^3.10.1",
    "marked": "^12.0.0",
    "mermaid": "^11.12.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.3.3"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^4.6.2",
    "postcss": "^8.4.32",
    "prettier": "^3.8.4",
    "tailwindcss": "^3.4.1",
    "vite": "^5.0.8"
  }
}
